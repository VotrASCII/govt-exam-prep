# Email settings for sending generated question PDFs.
# Copy this file to .env and replace the placeholders.

# Gmail example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_character_gmail_app_password

# Optional. If unset, SMTP_USER is used as the sender.
SMTP_FROM=your_email@gmail.com

# Optional default recipient. You can also pass --email-to on the command line.
QUESTIONS_EMAIL_TO=receiver@example.com
